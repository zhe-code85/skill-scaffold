#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: $0 <target-dir>"
}

if [ "$#" -ne 1 ]; then
  usage
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SOURCE_SCRIPT="$SCRIPT_DIR/link-skills"
TARGET_DIR="$1"

if [ ! -e "$SOURCE_SCRIPT" ]; then
  echo "Error: source script not found at $SOURCE_SCRIPT"
  exit 1
fi

if [ -e "$TARGET_DIR" ] && [ ! -d "$TARGET_DIR" ]; then
  echo "Error: target path exists and is not a directory: $TARGET_DIR"
  exit 1
fi

mkdir -p "$TARGET_DIR"
TARGET_DIR="$(cd "$TARGET_DIR" && pwd)"
LINK_PATH="$TARGET_DIR/link-skills"

if [ -L "$LINK_PATH" ]; then
  CURRENT_TARGET="$(readlink "$LINK_PATH")"
  if [ "$CURRENT_TARGET" = "$SOURCE_SCRIPT" ]; then
    echo "Already linked: $LINK_PATH"
    exit 0
  fi

  rm "$LINK_PATH"
elif [ -e "$LINK_PATH" ]; then
  echo "Error: target exists and is not a symlink: $LINK_PATH"
  exit 1
fi

ln -s "$SOURCE_SCRIPT" "$LINK_PATH"
echo "Linked $LINK_PATH -> $SOURCE_SCRIPT"
